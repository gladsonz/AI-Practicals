    asyncio.create_task(redis_event_listener())

@app.websocket("/api/v1/ws/store/{store_id}")
async def websocket_store_endpoint(websocket: WebSocket, store_id: str):
    await manager.connect_staff(store_id, websocket)
    try:
        while True:
            # Persistent socket loop to receive messages and manage connections
            data = await websocket.receive_text()
            payload = json.loads(data)
            
            # Handle inbound ping checks to survive mobile network adjustments
            if payload.get("type") == "ping":
                await websocket.send_text(json.dumps({"type": "pong"}))
    except WebSocketDisconnect:
        manager.disconnect_staff(store_id, websocket)

@app.websocket("/api/v1/ws/user/{user_id}")
async def websocket_user_endpoint(websocket: WebSocket, user_id: str):
