1.1 Edge Network Layer Configuration
Nginx acts as the Layer 7 router, terminating TLS certificates and optimizing TCP socket parameters to prevent thread exhaustion from thousands of lingering customer connections.

Nginx
# /etc/nginx/nginx.conf

user nginx;
worker_processes auto;
worker_rlimit_nofile 65535;

events {
    worker_connections 8192;
    use epoll;
    multi_accept on;
}

http {
    include /etc/nginx/mime.types;
    default_type application/octet-stream;

    # Optimization Parameters
    sendfile on;
    tcp_nopush on;
    tcp_nodelay on;
    keepalive_timeout 65;
    types_hash_max_size 2048;
    server_tokens off;

    # Gzip Compression for Fast Menu Loads
    gzip on;
    gzip_disable "msie6";
    gzip_comp_level 5;
    gzip_types text/plain text/css application/json application/javascript text/xml;

    upstream fastapi_backend {
        server web-backend:8000;
        keepalive 32; # Keep-alive connections to backend workers
    }

    server {
        listen 80;
        server_name app.localoutlet.com;
        return 301 https://$host$request_uri;
    }

    server {
        listen 443 ssl http2;
        server_name app.localoutlet.com;

        ssl_certificate /etc/letsencrypt/live/app.localoutlet.com/fullchain.pem;
        ssl_certificate_key /etc/letsencrypt/live/app.localoutlet.com/privkey.pem;
        ssl_protocols TLSv1.2 TLSv1.3;
        ssl_ciphers HIGH:!aNULL:!MD5;

        # Static Assets (Menu Images) Cached at Edge
        location /static/ {
            alias /var/www/static/;
            expires 7d;
            add_header Cache-Control "public, no-transform";
        }

        # Stateless REST API Routing
        location /api/v1/ {
            proxy_pass http://fastapi_backend;
            proxy_http_version 1.1;
            proxy_set_header Connection "";
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
        }

        # Stateful WebSocket Upgrade Routing
        location /api/v1/ws/ {
            proxy_pass http://fastapi_backend;
            proxy_http_version 1.1;
            proxy_set_header Upgrade $http_upgrade;
            proxy_set_header Connection "Upgrade";
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            
            # Prevent Timeout Disconnections for Active Connections
            proxy_read_timeout 3600s;
            proxy_send_timeout 3600s;
        }
    }
}
