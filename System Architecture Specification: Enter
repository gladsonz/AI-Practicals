To verify the health and connectivity of all running containers after spinning up the stack, execute the following diagnostic check sequence on your host terminal:

Bash
#!/usr/bin/env bash
# deployment-verify.sh
set -e

echo "=== Beginning Infrastructure Health Check ==="

# Check if all core docker containers are running smoothly
containers=("production_redis_broker" "production_postgres_engine" "production_api_server" "production_edge_proxy")
for container in "${containers[@]}"; do
    if [ "$(docker inspect -f '{{.State.Running}}' "$container" 2>/dev/null)" = "true" ]; then
        echo "✔ Container $container is active."
    else
        echo "✘ Container $container is down or missing."
        exit 1
    fi
done

# Test the operational integrity of the database connection loop
echo "Verifying database network availability..."
docker exec production_postgres_engine pg_isready -U postgres_admin -d outlet_ledger

# Confirm Redis is responding to connection requests
echo "Testing memory cache connectivity..."
redis_ping=$(docker exec production_redis_broker redis-cli ping)
if [ "$redis_ping" = "PONG" ]; then
    echo "✔ Redis connectivity confirmed."
else
    echo "✘ Redis connection failed."
    exit 1
fi

echo "=== System deployment verified successfully ==="