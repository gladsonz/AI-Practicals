# backend/main.py
import asyncio
import json
import logging
from typing import Dict, Set
from pydantic import BaseModel
import redis.asyncio as aioredis
from fastapi import FastAPI, WebSocket, WebSocketDisconnect, HTTPException, status

logging.basicConfig(level=logging.INFO)
logger = logging.getLogger("Engine")

app = FastAPI(title="Real-Time Engine")

# Hardware/Service URI bindings via production environments
REDIS_URL = "redis://redis-broker:6379/0"

class ConnectionManager:
    """Manages ephemeral in-memory WebSockets sorted by entity identifiers."""
    def __init__(self):
        # Maps active Store IDs to active connection instances
        self.active_store_connections: Dict[str, Set[WebSocket]] = {}
        # Maps specific User IDs to target user sockets
        self.active_user_connections: Dict[str, WebSocket] = {}

    async def connect_staff(self, store_id: str, websocket: WebSocket):
        await websocket.accept()
        if store_id not in self.active_store_connections:
            self.active_store_connections[store_id] = set()
        self.active_store_connections[store_id].add(websocket)
        logger.info(f"Staff connected to stream channel: {store_id}")

    def disconnect_staff(self, store_id: str, websocket: WebSocket):
        if store_id in self.active_store_connections:
            self.active_store_connections[store_id].remove(websocket)
            if not self.active_store_connections[store_id]:
                del self.active_store_connections[store_id]
        logger.info(f"Staff severed connection from channel: {store_id}")

    async def connect_user(self, user_id: str, websocket: WebSocket):
        await websocket.accept()
        self.active_user_connections[user_id] = websocket
        logger.info(f"Customer connected to stream socket: {user_id}")

    def disconnect_user(self, user_id: str):
        if user_id in self.active_user_connections:
            del self.active_user_connections[user_id]
        logger.info(f"Customer severed socket layer: {user_id}")

    async def send_to_user(self, user_id: str, payload: dict):
        ws = self.active_user_connections.get(user_id)
        if ws:
            try:
                await ws.send_text(json.dumps(payload))
            except Exception as e:
                logger.error(f"Failed packet push to user {user_id}: {str(e)}")

    async def broadcast_to_store(self, store_id: str, payload: dict):
        sockets = self.active_store_connections.get(store_id, set())
        if sockets:
            # Concurrent dispatch execution across all matched nodes
            await asyncio.gather(
                *[ws.send_text(json.dumps(payload)) for ws in sockets],
                return_exceptions=True
            )

manager = ConnectionManager()
redis_client = aioredis.from_url(REDIS_URL, decode_responses=True)

# 3.3 The Architecture Multi-Worker Synchronization Engine (Redis Pub/Sub)
async def redis_event_listener():
    """Listens to global Redis system events to synchronize isolated app worker runtimes."""
    pubsub = redis_client.pubsub()
    await pubsub.subscribe("global_order_events")
    logger.info("Asynchronous Message Broker Subscribed to channel: global_order_events")
    
    try:
        async for message in pubsub.listen():
            if message["type"] == "message":
                event_data = json.loads(message["data"])
                target_store = event_data.get("store_id")
                target_user = event_data.get("user_id")
                
                # Direct concurrent multiplex routing
                if target_store:
                    await manager.broadcast_to_store(target_store, event_data)
                if target_user:
                    await manager.send_to_user(target_user, event_data)
    except asyncio.CancelledError:
        await pubsub.unsubscribing()

@app.on_event("startup")
async def startup_event():
    # Launches internal multi-worker sync daemon task
    asyncio.create_task(redis_event_listener())

# 3.4 WebSocket Route Handlers
@app.on_event("startup")
